<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Gestion Stock Frigorifique{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>❄️</text></svg>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% block stylesheets %}{% endblock %}
</head>
<body>
    {% if app.user %}
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container-fluid">
            <a class="navbar-brand" href="{{ path('app_dashboard') }}">
                <i class="bi bi-snow"></i> Stock Frigo
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_dashboard') }}">
                            <i class="bi bi-speedometer2"></i> Tableau de bord
                        </a>
                    </li>
                    
                    {% if is_granted('ROLE_CONTROLEUR') or is_granted('ROLE_CHEF_STOCK') %}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-box-seam"></i> Stock
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="{{ path('app_stock_index') }}">État du stock</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_stock_entry_index') }}">Entrées</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_stock_exit_index') }}">Sorties</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_cold_room_index') }}">
                            <i class="bi bi-thermometer-snow"></i> Chambres froides
                        </a>
                    </li>
                    {% endif %}

                    {% if is_granted('ROLE_CLIENT') and not is_granted('ROLE_CONTROLEUR') %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_stock_index') }}">
                            <i class="bi bi-box-seam"></i> Mon stock
                        </a>
                    </li>
                    {% endif %}

                    {% if is_granted('ROLE_CHEF_STOCK') %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_client_index') }}">
                            <i class="bi bi-people"></i> Clients
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_user_index') }}">
                            <i class="bi bi-person-gear"></i> Utilisateurs
                        </a>
                    </li>
                    {% endif %}

                    {% if is_granted('ROLE_CHEF_STOCK') or is_granted('ROLE_DIRECTEUR') or is_granted('ROLE_PATRON') %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_invoice_index') }}">
                            <i class="bi bi-receipt"></i> Factures
                        </a>
                    </li>
                    {% endif %}

                    {% if is_granted('ROLE_DIRECTEUR') or is_granted('ROLE_PATRON') %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_reports') }}">
                            <i class="bi bi-graph-up"></i> Rapports
                        </a>
                    </li>
                    {% endif %}

                    {% if is_granted('ROLE_CLIENT') and not is_granted('ROLE_CONTROLEUR') %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_invoice_index') }}">
                            <i class="bi bi-receipt"></i> Mes factures
                        </a>
                    </li>
                    {% endif %}

                    {% if is_granted('ROLE_CHEF_STOCK') %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_history_index') }}">
                            <i class="bi bi-clock-history"></i> Historique
                        </a>
                    </li>
                    {% endif %}
                </ul>
                
                <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle"></i> {{ app.user.fullName }}
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><span class="dropdown-item-text text-muted">{{ app.user.email }}</span></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" href="{{ path('app_logout') }}">
                                    <i class="bi bi-box-arrow-right"></i> Déconnexion
                                </a>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    {% endif %}

    {% block body %}{% endblock %}

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>
