{% extends 'base.html.twig' %}

{% block title %}Factures{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">
                <i class="bi bi-receipt me-2"></i>Factures
            </h1>
            <p class="text-muted mb-0">Gestion et suivi des factures clients</p>
        </div>
        {% if is_granted('INVOICE_CREATE') %}
        <a href="{{ path('app_invoice_generate') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Générer une facture
        </a>
        {% endif %}
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">
            <i class="bi bi-check-circle me-2"></i>{{ message }}
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-circle me-2"></i>{{ message }}
        </div>
    {% endfor %}

    <div class="card mb-4">
        <div class="card-header">
            <i class="bi bi-funnel me-2"></i>Filtres
        </div>
        <div class="card-body">
            {{ form_start(filterForm, {'attr': {'class': 'row g-3'}}) }}
                <div class="col-md-3">{{ form_row(filterForm.client) }}</div>
                <div class="col-md-2">{{ form_row(filterForm.status) }}</div>
                <div class="col-md-2">{{ form_row(filterForm.dateFrom) }}</div>
                <div class="col-md-2">{{ form_row(filterForm.dateTo) }}</div>
                <div class="col-md-3 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search me-1"></i>Filtrer
                    </button>
                    <a href="{{ path('app_invoice_index') }}" class="btn btn-outline-secondary">Réinitialiser</a>
                </div>
            {{ form_end(filterForm) }}
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <i class="bi bi-list-ul me-2"></i>Liste des factures
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>N° Facture</th>
                            <th>Client</th>
                            <th>Période</th>
                            <th>Total HT</th>
                            <th>Total TTC</th>
                            <th>Statut</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for invoice in invoices %}
                        <tr>
                            <td>
                                <a href="{{ path('app_invoice_show', {id: invoice.id}) }}" class="fw-semibold text-primary">
                                    {{ invoice.invoiceNumber }}
                                </a>
                            </td>
                            <td>{{ invoice.client.companyName }}</td>
                            <td>
                                <small class="text-muted">
                                    {{ invoice.periodStart|date('d/m/Y') }} - {{ invoice.periodEnd|date('d/m/Y') }}
                                </small>
                            </td>
                            <td>{{ invoice.totalHt|number_format(2, ',', ' ') }} DH</td>
                            <td>
                                <span class="badge bg-success">{{ invoice.totalTtc|number_format(2, ',', ' ') }} DH</span>
                            </td>
                            <td>
                                {% if invoice.status.value == 'draft' %}
                                    <span class="badge bg-secondary">Brouillon</span>
                                {% elseif invoice.status.value == 'pending_validation' %}
                                    <span class="badge bg-warning">En attente</span>
                                {% elseif invoice.status.value == 'validated' %}
                                    <span class="badge bg-success">Validée</span>
                                {% elseif invoice.status.value == 'paid' %}
                                    <span class="badge bg-info">Payée</span>
                                {% else %}
                                    <span class="badge bg-primary">{{ invoice.status.value }}</span>
                                {% endif %}
                            </td>
                            <td>
                                <small class="text-muted">{{ invoice.createdAt|date('d/m/Y') }}</small>
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a href="{{ path('app_invoice_show', {id: invoice.id}) }}" class="btn btn-outline-primary" title="Voir">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    {% if is_granted('INVOICE_EXPORT') %}
                                    <a href="{{ path('app_invoice_pdf', {id: invoice.id}) }}" class="btn btn-outline-secondary" title="PDF" target="_blank">
                                        <i class="bi bi-file-pdf"></i>
                                    </a>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="8" class="text-center py-5">
                                <i class="bi bi-receipt text-muted" style="font-size: 3rem;"></i>
                                <p class="text-muted mt-2 mb-0">Aucune facture trouvée</p>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
