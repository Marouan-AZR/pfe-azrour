{% extends 'base.html.twig' %}

{% block title %}Facture {{ invoice.invoiceNumber }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    <div class="page-header">
        <div class="header-content">
            <div class="header-title">
                <h1><i class="bi bi-receipt"></i> Facture {{ invoice.invoiceNumber }}</h1>
                <div class="header-badges">
                    {% if invoice.status.value == 'draft' %}
                        <span class="status-badge status-draft"><i class="bi bi-pencil"></i> Brouillon</span>
                    {% elseif invoice.status.value == 'pending_validation' %}
                        <span class="status-badge status-pending"><i class="bi bi-hourglass-split"></i> En attente</span>
                    {% elseif invoice.status.value == 'validated' %}
                        <span class="status-badge status-validated"><i class="bi bi-check-circle"></i> Validée</span>
                    {% else %}
                        <span class="status-badge status-sent"><i class="bi bi-send"></i> Envoyée</span>
                    {% endif %}
                </div>
            </div>
            <div class="header-actions">
                {% if invoice.status.value == 'pending_validation' and is_granted('INVOICE_VALIDATE') %}
                <form action="{{ path('app_invoice_validate', {id: invoice.id}) }}" method="post" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('validate' ~ invoice.id) }}">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg"></i> Valider
                    </button>
                </form>
                {% endif %}
                {% if is_granted('INVOICE_EXPORT') %}
                <a href="{{ path('app_invoice_pdf', {id: invoice.id}) }}" class="btn btn-secondary" target="_blank">
                    <i class="bi bi-file-pdf"></i> PDF
                </a>
                {% endif %}
                <a href="{{ path('app_invoice_index') }}" class="btn btn-outline-light">
                    <i class="bi bi-arrow-left"></i> Retour
                </a>
            </div>
        </div>
    </div>

    <div class="invoice-container">
        <div class="invoice-header-section">
            <div class="invoice-party">
                <div class="party-label">Émetteur</div>
                <div class="party-name">Golden Logistics</div>
                <div class="party-details">
                    Zone Industrielle, Dakhla<br>
                    Maroc<br>
                    contact@golden-logistics.ma
                </div>
            </div>
            <div class="invoice-party">
                <div class="party-label">Client</div>
                <div class="party-name">{{ invoice.client.companyName }}</div>
                <div class="party-details">
                    {{ invoice.client.address|nl2br }}<br>
                    {{ invoice.client.email }}<br>
                    {{ invoice.client.phone }}
                </div>
            </div>
            <div class="invoice-meta">
                <div class="meta-item">
                    <span class="meta-label">Période</span>
                    <span class="meta-value">{{ invoice.periodStart|date('d/m/Y') }} - {{ invoice.periodEnd|date('d/m/Y') }}</span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">Créée le</span>
                    <span class="meta-value">{{ invoice.createdAt|date('d/m/Y') }}</span>
                </div>
                {% if invoice.validatedAt %}
                <div class="meta-item">
                    <span class="meta-label">Validée le</span>
                    <span class="meta-value">{{ invoice.validatedAt|date('d/m/Y') }}</span>
                </div>
                {% endif %}
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <i class="bi bi-list-ul"></i> Lignes de facturation
            </div>
            <div class="card-body p-0">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Produit</th>
                            <th class="text-end">Quantité (T)</th>
                            <th class="text-end">Jours stockage</th>
                            <th class="text-end">Tarif/jour/T</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for line in invoice.lines %}
                        <tr>
                            <td>
                                <span class="product-name">{{ line.productName }}</span>
                            </td>
                            <td class="text-end">{{ line.quantityTons|number_format(3, ',', ' ') }}</td>
                            <td class="text-end">{{ line.storageDays }}</td>
                            <td class="text-end">{{ line.dailyRatePerTon|number_format(4, ',', ' ') }} DH</td>
                            <td class="text-end"><span class="amount">{{ line.lineTotal|number_format(2, ',', ' ') }} DH</span></td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                                <p class="mt-2 mb-0">Aucune ligne de facturation</p>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="invoice-totals">
            <div class="totals-card">
                <div class="total-row">
                    <span class="total-label">Total HT</span>
                    <span class="total-value">{{ invoice.totalHt|number_format(2, ',', ' ') }} DH</span>
                </div>
                <div class="total-row">
                    <span class="total-label">TVA ({{ invoice.vatRate }}%)</span>
                    <span class="total-value">{{ ((invoice.totalTtc - invoice.totalHt))|number_format(2, ',', ' ') }} DH</span>
                </div>
                <div class="total-row total-final">
                    <span class="total-label">Total TTC</span>
                    <span class="total-value">{{ invoice.totalTtc|number_format(2, ',', ' ') }} DH</span>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.page-header {
    margin-bottom: 2rem;
}
.header-content {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1rem;
}
.header-title h1 {
    margin-bottom: 0.5rem;
}
.header-badges {
    display: flex;
    gap: 0.5rem;
}
.header-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
}
.status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.85rem;
}
.status-draft {
    background: rgba(100, 116, 139, 0.2);
    color: #94a3b8;
}
.status-pending {
    background: rgba(245, 158, 11, 0.2);
    color: #fbbf24;
}
.status-validated {
    background: rgba(16, 185, 129, 0.2);
    color: #34d399;
}
.status-sent {
    background: rgba(14, 165, 233, 0.2);
    color: #38bdf8;
}
.invoice-container {
    max-width: 1000px;
}
.invoice-header-section {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: var(--glass-bg);
    border-radius: var(--radius);
    border: 1px solid var(--glass-border);
}
.party-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
}
.party-name {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
}
.party-details {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
}
.invoice-meta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}
.meta-item {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--glass-border);
}
.meta-label {
    color: var(--text-muted);
    font-size: 0.85rem;
}
.meta-value {
    color: var(--text);
    font-weight: 500;
}
.product-name {
    font-weight: 500;
    color: var(--text);
}
.amount {
    font-weight: 600;
    color: var(--primary-light);
}
.invoice-totals {
    display: flex;
    justify-content: flex-end;
    margin-top: 2rem;
}
.totals-card {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius);
    padding: 1.5rem;
    min-width: 300px;
}
.total-row {
    display: flex;
    justify-content: space-between;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--glass-border);
}
.total-row:last-child {
    border-bottom: none;
}
.total-label {
    color: var(--text-muted);
}
.total-value {
    font-weight: 600;
    color: var(--text);
}
.total-final {
    margin-top: 0.5rem;
    padding-top: 1rem;
    border-top: 2px solid var(--primary);
}
.total-final .total-label,
.total-final .total-value {
    font-size: 1.2rem;
    color: var(--primary-light);
}
@media (max-width: 768px) {
    .invoice-header-section {
        grid-template-columns: 1fr;
    }
    .header-content {
        flex-direction: column;
    }
}
</style>
{% endblock %}
