{% extends 'base.html.twig' %}

{% block title %}Nouvelle entrée de stock{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="page-header">
        <div class="header-content">
            <h1><i class="bi bi-box-arrow-in-down"></i> Nouvelle entrée de stock</h1>
            <a href="{{ path('app_stock_entry_index') }}" class="btn btn-outline-light">
                <i class="bi bi-arrow-left"></i> Retour
            </a>
        </div>
    </div>

    <div class="form-container">
        {{ form_start(form, {'attr': {'class': 'entry-form'}}) }}
        
        <div class="form-section">
            <div class="section-header">
                <i class="bi bi-person-badge"></i>
                <h3>Informations client</h3>
            </div>
            <div class="form-grid">
                <div class="form-group">
                    {{ form_label(form.client) }}
                    {{ form_widget(form.client) }}
                    {{ form_errors(form.client) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.cdLotClient) }}
                    {{ form_widget(form.cdLotClient) }}
                    {{ form_errors(form.cdLotClient) }}
                    <small class="form-hint">Code lot interne du client</small>
                </div>
            </div>
        </div>

        <div class="form-section">
            <div class="section-header">
                <i class="bi bi-box-seam"></i>
                <h3>Informations produit</h3>
            </div>
            <div class="form-grid form-grid-3">
                <div class="form-group">
                    {{ form_label(form.productName) }}
                    {{ form_widget(form.productName) }}
                    {{ form_errors(form.productName) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.famille) }}
                    {{ form_widget(form.famille) }}
                    {{ form_errors(form.famille) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.qualite) }}
                    {{ form_widget(form.qualite) }}
                    {{ form_errors(form.qualite) }}
                </div>
            </div>
            <div class="form-grid form-grid-4">
                <div class="form-group">
                    {{ form_label(form.moule) }}
                    {{ form_widget(form.moule) }}
                    {{ form_errors(form.moule) }}
                    <small class="form-hint">Calibre du produit</small>
                </div>
                <div class="form-group">
                    {{ form_label(form.nombreCartons) }}
                    {{ form_widget(form.nombreCartons) }}
                    {{ form_errors(form.nombreCartons) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.quantityTons) }}
                    {{ form_widget(form.quantityTons) }}
                    {{ form_errors(form.quantityTons) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.poidsNet) }}
                    {{ form_widget(form.poidsNet) }}
                    {{ form_errors(form.poidsNet) }}
                </div>
            </div>
        </div>

        <div class="form-section">
            <div class="section-header">
                <i class="bi bi-snow2"></i>
                <h3>Emplacement stockage</h3>
            </div>
            <div class="form-grid form-grid-4">
                <div class="form-group">
                    {{ form_label(form.coldRoom) }}
                    {{ form_widget(form.coldRoom) }}
                    {{ form_errors(form.coldRoom) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.rayon) }}
                    {{ form_widget(form.rayon) }}
                    {{ form_errors(form.rayon) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.codeRack) }}
                    {{ form_widget(form.codeRack) }}
                    {{ form_errors(form.codeRack) }}
                    <small class="form-hint">Ex: 1G, 5D, 22G...</small>
                </div>
                <div class="form-group">
                    {{ form_label(form.codePalette) }}
                    {{ form_widget(form.codePalette) }}
                    {{ form_errors(form.codePalette) }}
                </div>
            </div>
        </div>

        <div class="form-section">
            <div class="section-header">
                <i class="bi bi-truck"></i>
                <h3>Transport & Réception</h3>
            </div>
            <div class="form-grid form-grid-3">
                <div class="form-group">
                    {{ form_label(form.transporteur) }}
                    {{ form_widget(form.transporteur) }}
                    {{ form_errors(form.transporteur) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.immatriculation) }}
                    {{ form_widget(form.immatriculation) }}
                    {{ form_errors(form.immatriculation) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.temperature) }}
                    {{ form_widget(form.temperature) }}
                    {{ form_errors(form.temperature) }}
                    <small class="form-hint">Température à réception</small>
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary btn-lg">
                <i class="bi bi-check-lg"></i> Enregistrer l'entrée
            </button>
            <a href="{{ path('app_stock_entry_index') }}" class="btn btn-secondary btn-lg">
                <i class="bi bi-x-lg"></i> Annuler
            </a>
        </div>

        {{ form_end(form) }}
    </div>
</div>

<style>
.page-header {
    margin-bottom: 2rem;
}
.header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
}
.form-container {
    max-width: 1000px;
}
.form-section {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
}
.section-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--glass-border);
}
.section-header i {
    font-size: 1.5rem;
    color: var(--primary-light);
}
.section-header h3 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
}
.form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
}
.form-grid-3 {
    grid-template-columns: repeat(3, 1fr);
}
.form-grid-4 {
    grid-template-columns: repeat(4, 1fr);
}
.form-group {
    display: flex;
    flex-direction: column;
}
.form-group label {
    color: var(--text);
    font-weight: 500;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
}
.form-group .form-control,
.form-group .form-select {
    background: var(--dark-light);
    border: 1px solid var(--glass-border);
    color: var(--text);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1rem;
    transition: all 0.3s ease;
}
.form-group .form-control:focus,
.form-group .form-select:focus {
    background: var(--dark-lighter);
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
}
.form-group .form-control::placeholder {
    color: var(--text-muted);
}
.form-hint {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
}
.form-actions {
    display: flex;
    gap: 1rem;
    justify-content: flex-start;
    padding-top: 1rem;
}
.btn-lg {
    padding: 0.75rem 2rem;
    font-size: 1rem;
}
@media (max-width: 992px) {
    .form-grid-4 {
        grid-template-columns: repeat(2, 1fr);
    }
}
@media (max-width: 768px) {
    .form-grid,
    .form-grid-3,
    .form-grid-4 {
        grid-template-columns: 1fr;
    }
    .form-actions {
        flex-direction: column;
    }
    .form-actions .btn {
        width: 100%;
    }
}
</style>
{% endblock %}
